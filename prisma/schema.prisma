// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CharacterGold {
  id           Int     @id @default(autoincrement())
  name         String  @unique
  gold         Int
  dailyExpense Int
  isNpc        Boolean
  friend       String?
  day          Int?
}

model ItemsInfo {
  id      Int    @id @default(autoincrement())
  name    String @unique
  quality Int
  unit    String
  type    String
  noSpace String @unique
}

model Inventory {
  id       Int    @id @default(autoincrement())
  itemName String
  amount   Int
  owner    String

  @@unique([owner, itemName])
}

model ItemAlias {
  id       Int    @id @default(autoincrement())
  alias    String @unique
  itemName String
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  passwordHash String
  passwordSalt String
  isAdmin      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  sessions     UserSession[]
  encounters   Encounter[]
  unitPresetFolders UnitPresetFolder[]
  unitPresets        UnitPreset[]
  tagPresetFolders  TagPresetFolder[]
  tagPresets         TagPreset[]
  worldMaps          WorldMap[]
}

model UserSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Encounter {
  id        String          @id @default(cuid())
  ownerId   String
  name      String
  state     Json
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  undo      EncounterUndo[]
}

model EncounterUndo {
  id          Int       @id @default(autoincrement())
  encounterId String
  state       Json
  createdAt   DateTime  @default(now())
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, createdAt])
}

model UnitPresetFolder {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  order     Int      @default(0)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parent    UnitPresetFolder? @relation("UnitPresetFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  UnitPresetFolder[] @relation("UnitPresetFolderTree")
  presets   UnitPreset[]

  @@index([ownerId])
  @@index([parentId])
}

model UnitPreset {
  id        String   @id @default(cuid())
  ownerId   String
  folderId  String?
  name      String
  order     Int      @default(0)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  folder    UnitPresetFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([folderId])
}

model TagPreset {
  id             String   @id @default(cuid())
  ownerId        String
  folderId       String?
  name           String
  order          Int      @default(0)
  kind           String
  decOnTurnStart Boolean  @default(false)
  decOnTurnEnd   Boolean  @default(false)
  colorCode      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  folder         TagPresetFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([folderId])
}

model TagPresetFolder {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  order     Int      @default(0)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parent    TagPresetFolder? @relation("TagPresetFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  TagPresetFolder[] @relation("TagPresetFolderTree")
  presets   TagPreset[]

  @@index([ownerId])
  @@index([parentId])
}

model SpellEntry {
  id               Int      @id @default(autoincrement())
  spellKey         String   @unique
  sourceMessageId  String   @unique
  sourceMessageUrl String
  sourceChannelId  String
  sourceChannelName String
  sourceThreadId   String?
  sourceThreadName String?

  spellLevel       String
  spellNumber      Int?
  spellName        String
  titleRaw         String
  normalizedName   String

  school           String?
  rangeText        String?
  damage           String?
  learnText        String?
  checkText        String?
  concentration    String?
  duration         String?
  castCost         String?
  etcText          String?
  commentText      String?
  componentsText   String?

  bodyRaw          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([normalizedName])
  @@index([spellLevel])
}

model SkillEntry {
  id               Int      @id @default(autoincrement())
  skillKey         String   @unique
  sourceMessageId  String   @unique
  sourceMessageUrl String
  sourceChannelId  String
  sourceChannelName String
  sourceThreadId   String?
  sourceThreadName String?

  jobName          String
  skillName        String
  conditionText    String?
  titleRaw         String
  normalizedName   String
  bodyRaw          String

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([normalizedName])
  @@index([jobName])
}

model WorldMap {
  id                   String   @id @default(uuid())
  ownerId              String
  name                 String
  imageUrl             String?
  imageWidth           Int?
  imageHeight          Int?
  hexSize              Float
  originX              Float
  originY              Float
  cols                 Int
  rows                 Int
  orientation          String
  cityGlobal           Json
  tileStatePresets     Json?
  tileStateAssignments Json?
  tileRegionStates     Json?
  tileMemos            Json?
  buildingPresets      Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  owner                User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  buildingPresetRows   WorldMapBuildingPreset[]
  buildingInstances    WorldMapBuildingInstance[]
  tickLogs             WorldMapTickLog[]

  @@index([ownerId])
}

model WorldMapBuildingPreset {
  id             String   @id @default(cuid())
  mapId          String?
  name           String
  color          String
  tier           String?
  effort         Int?
  space          Int?
  description    String?
  placementRules Json?
  buildCost      Json?
  researchCost   Json?
  upkeep         Json?
  effects        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  map            WorldMap? @relation(fields: [mapId], references: [id], onDelete: Cascade)
  instances      WorldMapBuildingInstance[]

  @@index([mapId])
  @@index([mapId, name])
}

model WorldMapTileStatePreset {
  id        String   @id @default(cuid())
  name      String
  color     String
  hasValue  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorldMapBuildingInstance {
  id             String                 @id @default(cuid())
  mapId          String
  presetId       String
  col            Int
  row            Int
  enabled        Boolean                @default(true)
  progressEffort Int                    @default(0)
  meta           Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  map            WorldMap               @relation(fields: [mapId], references: [id], onDelete: Cascade)
  preset         WorldMapBuildingPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@index([mapId, col, row])
  @@index([presetId])
}

model WorldMapTickLog {
  id        String   @id @default(cuid())
  mapId     String
  day       Int
  summary   Json?
  createdAt DateTime @default(now())
  map       WorldMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId, day])
}

